##############################
# Global Projekt .gitignore #
##############################

### -------------------------
### IDEs (IntelliJ / JetBrains)
### -------------------------
**/.idea/
*.iml
*.ipr
*.iws

# IntelliJ special folders
**/workspace.xml
**/shelf/
**/httpRequests/
**/dataSources/
**/dataSources.local.xml

### -------------------------
### VS Code
### -------------------------
**/.vscode/
!**/.vscode/extensions.json

### -------------------------
### Node / Vite / React
### -------------------------
# Dependency directories
**/node_modules/

# Vite build output
**/dist/
**/dist-ssr/

# Local configs
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

### -------------------------
### Java / Spring Boot / Maven
### -------------------------
HELP.md

# Build output
**/target/
!projekt/backend/src/main/**/target/
!projekt/backend/src/test/**/target/

# Maven wrapper JAR
**/.mvn/wrapper/maven-wrapper.jar

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!projekt/backend/src/main/**/build/
!projekt/backend/src/test/**/build/

# STS (Spring Tools)
.apt_generated
.factorypath
.springBeans
.sts4-cache
.classpath
.project
.settings/

### -------------------------
### OS / Editor junk
### -------------------------
.DS_Store
Thumbs.db

### -------------------------
### Environment files
### -------------------------
.env
*.env.local
*.env.development.local
*.env.production.local
*.env.test.local


## GitHub
.github

